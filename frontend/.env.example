# Настройка адреса бэкенда (API)
#
# Docker / удалённый сервер: оставляй ПУСТЫМ. Тогда фронтенд работает в режиме
# same-origin, а nginx внутри образа сам проксирует /generate, /models, /outputs и т.д.
# на backend. Это значит один публичный URL (Cloudflare Tunnel) и никаких CORS.
#
# Локальная разработка через `npm run dev` (Vite на :5173, backend на :8000):
# укажи прямой адрес бэкенда, например http://localhost:8000
VITE_API_BASE_URL=
