# =====================================================================
# Канонический шаблон runtime-переменных backend.
# bootstrap.sh копирует его в deploy/backend.env и выставляет USE_CUDA
# по режиму (gpu/cpu). Это единственный источник правды для всех compose.
# =====================================================================

# --- Базовый runtime ---
# true на GPU-хосте (CUDA-torch), false на CPU. bootstrap.sh проставит сам.
USE_CUDA=true
DEFAULT_MODEL_ID=runwayml/stable-diffusion-v1-5
# Включай при дефиците VRAM; выключи, чтобы держать модель на GPU между генерациями.
SD_ENABLE_CPU_OFFLOAD=true
# Единый тумблер NSFW-защиты. true (по умолчанию): негатив-промпт + классификатор,
# который проверяет каждую готовую картинку и блокирует NSFW. Модель safety-checker
# (CompVis/stable-diffusion-safety-checker, ~1.2ГБ) скачивается ПЕРЕД генерацией;
# если не загрузилась — генерация вернёт ошибку (fail-closed). Разрешить NSFW —
# ТОЛЬКО осознанно: NSFW_FILTER_ENABLED=false (тогда классификатор не грузится).
NSFW_FILTER_ENABLED=true
CLIP_SKIP=1
# Отдавать собранный фронтенд тем же backend-ом (один origin = сайт + API).
# В vast включается флагом run-vast.sh --with-frontend (он же соберёт SPA).
# В Docker НЕ нужно — там фронт отдаёт nginx.
SERVE_FRONTEND=false
# Пароль для правки настроек из панели (шестерёнка в UI). Пусто = редактирование
# выключено (панель только показывает конфиг). Задай свой секрет, чтобы включить
# правку; backend пишет изменения в этот же .env (применяются после рестарта).
SETTINGS_ADMIN_TOKEN=

# --- Скачивание моделей через меню в редакторе ---
# Токен Civit.ai (нужен для части чекпоинтов, требующих авторизации).
CIVITAI_API_TOKEN=
# Токен HuggingFace (для приватных/gated репозиториев). Для публичных не нужен.
HF_TOKEN=

# --- Трансформация prompt ---
PROMPT_TRANSFORM_ENABLED=false
PROMPT_TRANSFORM_PROVIDER=stub
PROMPT_TRANSFORM_TIMEOUT_MS=1500
PROMPT_TRANSFORM_STRICT=true
PROMPT_NEGATIVE_MERGE_POLICY=append
NEG_PROMPT_TRANSFORM_ENABLED=false
NEG_PROMPT_TRANSFORM_PROVIDER=stub
NEG_PROMPT_TRANSFORM_TIMEOUT_MS=1500
NEG_PROMPT_TRANSFORM_STRICT=true
PROMPT_TRANSFORM_QUEUE_MODE=wait
PROMPT_TRANSFORM_MAX_WAIT_MS=20000

# --- Опциональный провайдер qwen_gguf ---
LLM_MODEL_PATH=/app/models/llm/model.gguf
LLM_LORA_PATH=
LLM_LORA_SCALE=1.0
LLM_CTX_SIZE=4096
LLM_THREADS=6
LLM_GPU_LAYERS=0
LLM_MAX_NEW_TOKENS=220
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9

# --- CORS ---
# При same-origin (фронтенд проксирует API через nginx) CORS не нужен.
# Эти значения важны только если обращаешься к backend напрямую с другого origin.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
