# Prompt Transformer Settings
PROMPT_TRANSFORM_ENABLED=true
PROMPT_TRANSFORM_TIMEOUT_MS=1500
PROMPT_TRANSFORM_PROVIDER=stub
PROMPT_TRANSFORM_STRICT=true
PROMPT_NEGATIVE_MERGE_POLICY=append

# CORS settings for remote frontend access via public URL
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Stable Diffusion runtime
# Keep enabled if VRAM is tight. Disable if you want one loaded SD model to stay on GPU between generations.
# SD_ENABLE_CPU_OFFLOAD=true
# CIVITAI_API_TOKEN=your_civitai_api_token
# NSFW_FILTER_ENABLED=true
# NSFW_NEGATIVE_PROMPT=nsfw, nude, naked, explicit, erotic, porn, sex, uncensored, nipples, breasts, genitalia
# CLIP_SKIP=1
# LIVE_PREVIEW_METHOD=full
# LIVE_PREVIEW_INTERVAL_STEPS=4

# Qwen GGUF + LoRA Settings (Uncomment and configure to use local LLM)
# PROMPT_TRANSFORM_PROVIDER=qwen_gguf
# LLM_MODEL_PATH=/abs/path/to/qwen3-1.7b.gguf
# LLM_LORA_PATH=/abs/path/to/your_adapter.gguf
# LLM_LORA_SCALE=1.0
# LLM_CTX_SIZE=4096
# LLM_THREADS=6
# LLM_GPU_LAYERS=0
# LLM_MAX_NEW_TOKENS=220
# LLM_TEMPERATURE=0.2
# LLM_TOP_P=0.9
